# Site to audit
SITE_URL=https://www.journeyrouters.com
SITEMAP_URL=https://www.journeyrouters.com/sitemap.xml

# Crawler settings
# How many pages to crawl simultaneously (keep low to avoid overloading your site)
CRAWL_CONCURRENCY=2
# Delay between requests in milliseconds
CRAWL_DELAY_MS=1500
# Timeout for each page load in milliseconds
PAGE_TIMEOUT_MS=25000
# How long to wait AFTER domcontentloaded for JS to render (critical for Next.js)
JS_RENDER_WAIT_MS=3000
# Max links to check per page (set higher for thoroughness, lower for speed)
MAX_LINKS_PER_PAGE=50
# Recycle browser every N pages to prevent memory leaks
BROWSER_RECYCLE_INTERVAL=15
